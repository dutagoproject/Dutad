[Unit]
Description=DUTA Daemon
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/.duta
ExecStart=/usr/local/bin/dutad --datadir /root/.duta/mainnet --mining-bind 0.0.0.0:19085
Restart=always
RestartSec=5
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
